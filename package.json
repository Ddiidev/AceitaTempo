    "smoke:sites": "node tests/run-sites-smoke.js",
    "smoke:cart": "node tests/run-cart-smoke.js",
    "smoke:social": "node tests/run-social-smoke.js",
    "smoke:firefox-onboarding": "node tests/run-firefox-onboarding-smoke.js",
