{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.0.2",
  "description": "__MSG_extensionDescription__",
  "default_locale": "pt_BR",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "aceitatempo@aceitatempo.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://open.er-api.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "action": {
    "default_title": "__MSG_extensionName__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.amazon.com.br/*",
        "https://*.amazon.ca/*",
        "https://*.amazon.co.uk/*",
        "https://*.amazon.de/*",
        "https://*.amazon.es/*",
        "https://*.amazon.fr/*",
        "https://*.amazon.it/*",
        "https://*.amazon.in/*",
        "https://*.amazon.com.mx/*",
        "https://*.amazon.com.au/*",
        "https://*.amzn.to/*",
        "https://*.amzn.com/*",
        "https://*.mercadolivre.com.br/*",
        "https://*.mercadolibre.com/*",
        "https://*.mercadolibre.com.ar/*",
        "https://*.mercadolibre.com.mx/*",
        "https://*.mercadolibre.com.co/*",
        "https://*.mercadolibre.cl/*",
        "https://*.mercadolibre.com.pe/*",
        "https://*.mercadolibre.com.uy/*",
        "https://*.magazineluiza.com.br/*",
        "https://*.ebay.com/*",
        "https://*.ebay.com.br/*",
        "https://*.ebay.co.uk/*",
        "https://*.ebay.de/*",
        "https://*.ebay.fr/*",
        "https://*.ebay.it/*",
        "https://*.ebay.es/*",
        "https://*.ebay.ca/*",
        "https://*.ebay.com.au/*",
        "https://*.aliexpress.com/*",
        "https://*.aliexpress.us/*",
        "https://*.stripe.com/*",
        "https://store.epicgames.com/*",
        "https://store.steampowered.com/*",
        "https://*.gog.com/*",
        "https://*.shopee.com/*",
        "https://*.shopee.com.br/*",
        "https://*.shopee.co.id/*",
        "https://*.shopee.sg/*",
        "https://*.shopee.vn/*",
        "https://*.shopee.co.th/*",
        "https://*.shopee.ph/*",
        "https://*.shopee.my/*",
        "https://*.shopee.tw/*",
        "https://*.shein.com/*",
        "https://*.shein.com.br/*",
        "https://*.shein.co.uk/*",
        "https://*.shein.de/*",
        "https://*.shein.fr/*",
        "https://*.shein.it/*",
        "https://*.shein.es/*",
        "https://*.shein.us/*",
        "https://*.armazemparaiba.com.br/*",
        "https://*.americanas.com.br/*",
        "*://*.pichau.com.br/*",
        "*://*.kabum.com.br/*",
        "*://*.terabyteshop.com.br/*",
        "https://*.temu.com/*",
        "https://*.alibaba.com/*",
        "https://*.alibaba.com.br/*",
        "https://instagram.com/*",
        "https://www.instagram.com/*",
        "https://m.instagram.com/*",
        "https://youtube.com/*",
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://music.youtube.com/*",
        "https://tiktok.com/*",
        "https://www.tiktok.com/*",
        "https://m.tiktok.com/*"
      ],
      "js": [
        "src/price-utils.js",
        "src/site-config.js",
        "src/social-awareness.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/*",
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}